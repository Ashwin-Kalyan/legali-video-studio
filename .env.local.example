# Google Gemini — Google AI Studio free API
# 1. Get a free key at https://aistudio.google.com  ->  "Get API key"
# 2. Copy this file to .env.local and paste your key below
# 3. Restart the dev server (pnpm dev)
GEMINI_API_KEY=

# Optional — override the model (defaults to gemini-2.5-flash, which is the
# model with free-tier quota on current AI Studio keys; gemini-2.0-flash is
# often 0-quota).
# GEMINI_MODEL=gemini-2.5-flash

# --- Instagram Graph API (real analytics for your own IG Business account) ---
# See README "Real Instagram data". When both are set, the AI Insight uses your
# live Instagram numbers instead of the sample fixtures.
IG_ACCESS_TOKEN=
IG_USER_ID=
# IG_API_VERSION=v21.0
